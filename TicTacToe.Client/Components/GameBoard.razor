@using TicTacToe.Shared.Models
@using TicTacToe.Client.Services
@inject IGameHubService GameHubService
@inject IApiService ApiService
@inject ILogger<GameBoard> Logger

<div class="game-container">
    <div class="game-header">
        <h1>Tic Tac Toe - Distributed Systems</h1>
        <div class="connection-status @(IsConnected ? "connected" : "disconnected")">
            @if (IsConnected)
            {
                <span>🟢 Connected</span>
            }
            else
            {
                <span>🔴 Disconnected</span>
            }
        </div>
    </div>

    @if (CurrentGame == null)
    {
        <div class="lobby">
            <h2>Game Lobby</h2>
            <div class="lobby-actions">
                <div class="create-game">
                    <h3>Create New Game</h3>
                    <div class="input-group">
                        <input @bind="PlayerName" @bind:event="oninput" placeholder="Enter your name" />
                        <button @onclick="CreateGame" disabled="@IsLoading">Create Game</button>
                    </div>
                </div>

                <div class="join-game">
                    <h3>Join Existing Game</h3>
                    <div class="input-group">
                        <input @bind="GameIdToJoin" @bind:event="oninput" placeholder="Enter game ID" />
                        <input @bind="PlayerNameToJoin" @bind:event="oninput" placeholder="Enter your name" />
                        <button @onclick="JoinGame" disabled="@IsLoading">Join Game</button>
                    </div>
                </div>

                <div class="active-games">
                    <h3>Active Games</h3>
                    @if (ActiveGames.Any())
                    {
                        <div class="games-list">
                            @foreach (var game in ActiveGames)
                            {
                                <div class="game-item">
                                    <span>Game: @game.Id.Substring(0, 8)...</span>
                                    <span>Players: @game.Players.Count/2</span>
                                    <span>Status: @game.Status</span>
                                    <button @onclick="() => JoinExistingGame(game.Id)" disabled="@(game.Players.Count >= 2)">
                                        Join
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p>No active games found.</p>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="game-area">
            <div class="game-info">
                <h2>Game: @CurrentGame.Id.Substring(0, 8)...</h2>
                <div class="players">
                    @foreach (var player in CurrentGame.Players)
                    {
                        <div class="player @(player.Symbol == CurrentGame.CurrentPlayer ? "current" : "")">
                            <span class="player-name">@player.Name (@player.Symbol)</span>
                            <span class="player-status @(player.IsConnected ? "online" : "offline")">
                                @(player.IsConnected ? "🟢" : "🔴")
                            </span>
                        </div>
                    }
                </div>
                <div class="game-status">
                    @if (CurrentGame.Status == GameStatus.Waiting)
                    {
                        <p>Waiting for players...</p>
                    }
                    else if (CurrentGame.Status == GameStatus.Playing)
                    {
                        <p>Current player: @CurrentGame.CurrentPlayer</p>
                    }
                    else if (CurrentGame.Status == GameStatus.Finished)
                    {
                        @if (CurrentGame.Winner != null)
                        {
                            <p class="winner">Winner: @CurrentGame.Winner!</p>
                        }
                        else
                        {
                            <p class="draw">It's a draw!</p>
                        }
                    }
                </div>
            </div>

            <div class="board">
                @for (int i = 0; i < 9; i++)
                {
                    var index = i;
                    bool canMove = CurrentGame != null &&
                                   CurrentPlayer != null &&
                                   CurrentGame.Status == GameStatus.Playing &&
                                   CurrentPlayer.Symbol == CurrentGame.CurrentPlayer &&
                                   string.IsNullOrEmpty(CurrentGame.Board[index]);
                    <div class="cell @(IsWinningCell(index) ? "winning" : "")"
                         @onclick="() => MakeMove(index)"
                         style="pointer-events:@(canMove ? "auto" : "none");opacity:@(canMove ? "1" : "0.5");">
                        @if (CurrentGame != null && !string.IsNullOrEmpty(CurrentGame.Board[index]))
                        {
                            <span class="symbol @(CurrentGame?.Board[index]?.ToLower())">@(CurrentGame?.Board[index])</span>
                        }
                    </div>
                }
            </div>

            <div class="game-actions">
                @if (CurrentGame != null && CurrentGame.Status == GameStatus.Finished)
                {
                    <button @onclick="RestartGame" class="restart-btn">Play Again</button>
                }
                <button @onclick="LeaveGame" class="leave-btn">Leave Game</button>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-message">
            @ErrorMessage
            <button @onclick="ClearError">×</button>
        </div>
    }
</div>

<style>
