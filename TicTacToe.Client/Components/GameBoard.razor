</style>

@code {
    private GameState? CurrentGame;
    private List<GameState> ActiveGames = new();
    private string PlayerName = "";
    private string GameIdToJoin = "";
    private string PlayerNameToJoin = "";
    private string ErrorMessage = "";
    private bool IsLoading = false;
    private bool IsConnected = false;
    private PlayerInfo? CurrentPlayer;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await GameHubService.ConnectAsync();
            IsConnected = true;
            await LoadActiveGames();

            // Subscribe to SignalR events
            GameHubService.GameStateUpdated += OnGameStateUpdated;
            GameHubService.PlayerJoined += OnPlayerJoined;
            GameHubService.PlayerLeft += OnPlayerLeft;
            GameHubService.GameStarted += OnGameStarted;
            GameHubService.GameEnded += OnGameEnded;
            GameHubService.MoveMade += OnMoveMade;
            GameHubService.PlayerReconnected += OnPlayerReconnected;
            GameHubService.Error += OnError;
            GameHubService.NewGameCreated -= OnNewGameCreated; // Parandalon shumë regjistrime
    GameHubService.NewGameCreated += OnNewGameCreated;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize game service");
            ErrorMessage = "Failed to connect to game server";
        }
    }
    private void OnNewGameCreated(GameState newGame)
{
    if (!ActiveGames.Any(g => g.Id == newGame.Id))
    {
        ActiveGames.Add(newGame);
        ActiveGames = ActiveGames.OrderByDescending(g => g.CreatedAt).ToList();
        InvokeAsync(StateHasChanged);
    }
}

    private async Task LoadActiveGames()
    {
        try
        {
            ActiveGames = await ApiService.GetActiveGamesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load active games");
        }
    }

    private async Task CreateGame()
    {
        if (string.IsNullOrWhiteSpace(PlayerName))
        {
            ErrorMessage = "Please enter your name";
            return;
        }

        IsLoading = true;
        try
        {
            var request = new CreateGameRequest { PlayerName = PlayerName };
            var game = await ApiService.CreateGameAsync(request);
            CurrentGame = game;
            
            // Join the game via SignalR
            await GameHubService.JoinGameAsync(game.Id, PlayerName);
            
            // Set current player
            CurrentPlayer = game.Players.FirstOrDefault(p => p.Name == PlayerName);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create game");
            ErrorMessage = "Failed to create game";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task JoinGame()
    {
        if (string.IsNullOrWhiteSpace(GameIdToJoin) || string.IsNullOrWhiteSpace(PlayerNameToJoin))
        {
            ErrorMessage = "Please enter both game ID and player name";
            return;
        }

        IsLoading = true;
        try
        {
            // Join via SignalR to establish connection and add player
            await GameHubService.JoinGameAsync(GameIdToJoin, PlayerNameToJoin);
            
            // CurrentGame and CurrentPlayer will be set by the OnGameStateUpdated event handler
            // after the SignalR hub processes the join request.
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to join game: {ErrorMessage}", ex.Message);
            ErrorMessage = $"Failed to join game: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task JoinExistingGame(string gameId)
    {
        if (string.IsNullOrWhiteSpace(PlayerName))
        {
            ErrorMessage = "Please enter your name first";
            return;
        }

        GameIdToJoin = gameId;
        PlayerNameToJoin = PlayerName;
        await JoinGame();
    }

    private async Task MakeMove(int position)
    {
        if (CurrentGame == null || CurrentPlayer == null)
        {
            ErrorMessage = "Player not found.";
            return;
        }
        if (CurrentGame.Status != GameStatus.Playing)
        {
            ErrorMessage = "Game is not active.";
            return;
        }
        if (CurrentPlayer.Symbol != CurrentGame.CurrentPlayer)
        {
            ErrorMessage = "It's not your turn!";
            return;
        }
        if (!string.IsNullOrEmpty(CurrentGame.Board[position]))
        {
            ErrorMessage = "Cell already taken.";
            return;
        }
        try
        {
            await GameHubService.MakeMoveAsync(CurrentGame.Id, CurrentPlayer.Id, position);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error making move");
            ErrorMessage = "Failed to make move: " + ex.Message;
        }
    }

    private async Task RestartGame()
    {
        if (CurrentGame == null) return;

        try
        {
            await GameHubService.RestartGameAsync(CurrentGame.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to restart game");
            ErrorMessage = "Failed to restart game";
        }
    }

    private async Task LeaveGame()
    {
        try
        {
            if (CurrentGame != null)
            {
                await GameHubService.LeaveGameAsync(CurrentGame.Id);
                CurrentGame = null;
                CurrentPlayer = null;
                StateHasChanged();
                await LoadActiveGames();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error leaving game");
            ErrorMessage = "Failed to leave game";
        }
    }

    private bool IsWinningCell(int position)
    {
        if (CurrentGame?.Winner == null) return false;
        
        // Simple winning line detection - in a real implementation, you'd track the winning line
        return false;
    }

    // SignalR event handlers
    private void OnGameStateUpdated(GameState gameState)
    {
        if (CurrentGame?.Id != gameState.Id) return;
        Console.WriteLine($"[GameBoard] OnGameStateUpdated: GameId={gameState.Id}, Board={string.Join(",", gameState.Board)}");
        CurrentGame = gameState;
        // Always update CurrentPlayer reference based on PlayerName
        if (!string.IsNullOrEmpty(PlayerName))
        {
            CurrentPlayer = gameState.Players.FirstOrDefault(p => p.Name == PlayerName);
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnPlayerJoined(PlayerInfo player)
    {
        Console.WriteLine($"[GameBoard] OnPlayerJoined: PlayerId={player.Id}, Name={player.Name}");
        Logger.LogInformation("Player joined: {PlayerName}", player.Name);
        InvokeAsync(StateHasChanged);
    }

    private void OnPlayerLeft(string playerId)
    {
        Console.WriteLine($"[GameBoard] OnPlayerLeft: PlayerId={playerId}");
        Logger.LogInformation("Player left: {PlayerId}", playerId);
        InvokeAsync(StateHasChanged);
    }

    private void OnGameStarted(GameState gameState)
    {
        Console.WriteLine($"[GameBoard] OnGameStarted: GameId={gameState.Id}");
        Logger.LogInformation("Game started");
        CurrentGame = gameState;
        InvokeAsync(StateHasChanged);
    }

    private void OnGameEnded(GameState gameState)
    {
        Console.WriteLine($"[GameBoard] OnGameEnded: GameId={gameState.Id}");
        Logger.LogInformation("Game ended");
        CurrentGame = gameState;
        InvokeAsync(StateHasChanged);
    }

    private void OnMoveMade(GameMove move)
    {
        if (CurrentGame?.Id != move.GameId) return;
        
        Console.WriteLine($"[GameBoard] OnMoveMade: GameId={move.GameId}, Position={move.Position}, Player={move.Player}");
        Logger.LogInformation("Move made at position {Position} by player {Player}", move.Position, move.Player);
        // We'll wait for the GameStateUpdated event to update the UI
    }

    private void OnPlayerReconnected(PlayerInfo player)
    {
        Console.WriteLine($"[GameBoard] OnPlayerReconnected: PlayerId={player.Id}, Name={player.Name}");
        Logger.LogInformation("Player reconnected: {PlayerName}", player.Name);
        InvokeAsync(StateHasChanged);
    }

    private void OnError(string error)
    {
        Console.WriteLine($"[GameBoard] OnError: {error}");
        ErrorMessage = error;
        StateHasChanged();
    }

    public void Dispose()
    {
        GameHubService.GameStateUpdated -= OnGameStateUpdated;
        GameHubService.PlayerJoined -= OnPlayerJoined;
        GameHubService.PlayerLeft -= OnPlayerLeft;
        GameHubService.GameStarted -= OnGameStarted;
        GameHubService.GameEnded -= OnGameEnded;
        GameHubService.MoveMade -= OnMoveMade;
        GameHubService.PlayerReconnected -= OnPlayerReconnected;
        GameHubService.Error -= OnError;
    }

    private void ClearError()
    {
        ErrorMessage = string.Empty;
        StateHasChanged();
    }
}